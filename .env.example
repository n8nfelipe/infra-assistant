# =============================================================
#  InfraStack - Environment Variables
#  Copie este arquivo para .env e preencha com seus valores:
#  cp .env.example .env
# =============================================================

# --------------------------------------------------------------
# OBRIGATÓRIO - Google Gemini API Key
# Obtenha gratuitamente em: https://aistudio.google.com/apikey
# --------------------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here

# --------------------------------------------------------------
# OPCIONAL - Porta da aplicação (padrão: 3001)
# --------------------------------------------------------------
PORT=3001

JWT_SECRET="a-string-secret-at-least-256-bits-long"
